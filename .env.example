# Server Port
PORT=8080

# CORS Configuration (whitelist origins, comma-separated)
ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Firebase Config Path (Optional: falls back to classpath resources/serviceAccountKey.json if blank)
# Set to a local path or paste the JSON text directly into FIREBASE_CREDENTIALS
FIREBASE_CREDENTIALS=
FIREBASE_CREDENTIALS_PATH=src/main/resources/serviceAccountKey.json
